{
  "get-addresses": {
    "endpoint": "GET /api/addresses",
    "description": "Get user's saved addresses",
    "authentication": "Required",
    "responses": {
      "200_ok": {
        "status": 200,
        "body": {
          "data": [
            {
              "id": 1,
              "userId": 123,
              "name": "Nguyễn Văn A",
              "phone": "0123456789",
              "address": "123 Đường ABC",
              "ward": "Phường 1",
              "district": "Quận 1",
              "city": "TP. Hồ Chí Minh",
              "country": "Vietnam",
              "isDefault": true,
              "createdAt": "2026-05-03T10:00:00Z",
              "updatedAt": "2026-05-03T10:00:00Z"
            }
          ]
        }
      }
    }
  },
  "create-address": {
    "endpoint": "POST /api/addresses",
    "description": "Create new address",
    "authentication": "Required",
    "request": {
      "body": {
        "name": "string (required)",
        "phone": "string (required)",
        "address": "string (required)",
        "ward": "string (required)",
        "district": "string (required)",
        "city": "string (required)",
        "country": "string (optional) - Default: Vietnam",
        "isDefault": "boolean (optional) - Default: false"
      }
    },
    "responses": {
      "201_created": {
        "status": 201,
        "body": {
          "data": {
            "id": 2,
            "name": "Nguyễn Văn B",
            "phone": "0987654321",
            "isDefault": false
          },
          "message": "Address created successfully"
        }
      }
    },
    "notes": [
      "If isDefault=true, other addresses are set to isDefault=false",
      "First address is automatically set as default"
    ]
  },
  "update-address": {
    "endpoint": "PUT /api/addresses/{id}",
    "description": "Update address",
    "authentication": "Required",
    "request": {
      "path": {
        "id": "number"
      },
      "body": {
        "name": "string (optional)",
        "phone": "string (optional)",
        "address": "string (optional)",
        "ward": "string (optional)",
        "district": "string (optional)",
        "city": "string (optional)",
        "country": "string (optional)",
        "isDefault": "boolean (optional)"
      }
    },
    "responses": {
      "200_updated": {
        "status": 200,
        "body": {
          "data": {
            "id": 2,
            "name": "Nguyễn Văn B Updated"
          },
          "message": "Address updated successfully"
        }
      },
      "404_not_found": {
        "status": 404,
        "body": {
          "status": 404,
          "code": "ADDRESS_NOT_FOUND",
          "message": "Address not found"
        }
      }
    }
  },
  "delete-address": {
    "endpoint": "DELETE /api/addresses/{id}",
    "description": "Delete address",
    "authentication": "Required",
    "request": {
      "path": {
        "id": "number"
      }
    },
    "responses": {
      "200_deleted": {
        "status": 200,
        "body": {
          "message": "Address deleted successfully"
        }
      },
      "409_cannot_delete_default": {
        "status": 409,
        "body": {
          "status": 409,
          "code": "CANNOT_DELETE_DEFAULT_ADDRESS",
          "message": "Cannot delete default address. Set another address as default first."
        }
      }
    }
  },
  "set-default-address": {
    "endpoint": "PATCH /api/addresses/{id}/set-default",
    "description": "Set address as default",
    "authentication": "Required",
    "request": {
      "path": {
        "id": "number"
      }
    },
    "responses": {
      "200_updated": {
        "status": 200,
        "body": {
          "message": "Default address updated"
        }
      }
    }
  }
}
