{
  "create": {
    "endpoint": "POST /api/brands",
    "description": "Tạo brand mới. Slug phải unique trong active records.",
    "request": {
      "body": {
        "name": "string (required)",
        "slug": "string (required, unique)",
        "logo": "string (optional, url)",
        "description": "string (optional)",
        "active": "boolean (required)"
      }
    },
    "responses": {
      "201_created": {
        "status": 201,
        "body": {
          "data": {
            "id": 15,
            "name": "Test Brand",
            "slug": "test-brand-1775710498",
            "logo": "https://example.com/logo.png",
            "description": "A test brand",
            "active": true,
            "createdAt": "2026-04-09T11:54:58.506284",
            "updatedAt": "2026-04-09T11:54:58.506284"
          },
          "message": "Created successfully"
        }
      },
      "409_slug_exists": {
        "status": 409,
        "body": {
          "status": 409,
          "code": "BRAND_SLUG_EXISTS",
          "message": "Slug already exists"
        }
      },
      "422_validation": {
        "status": 422,
        "body": {
          "status": 422,
          "code": "VALIDATION_ERROR",
          "message": "Validation failed",
          "errors": {
            "name": "Name is required",
            "slug": "Slug is required"
          }
        }
      }
    }
  },
  "delete": {
    "endpoint": "DELETE /api/brands/{id}",
    "description": "Soft delete brand. Brand vẫn còn trong DB, có thể restore.",
    "request": {
      "path": {
        "id": "number"
      }
    },
    "responses": {
      "200_ok": {
        "status": 200,
        "body": {
          "message": "Brand deleted successfully"
        }
      },
      "404_not_found": {
        "status": 404,
        "body": {
          "status": 404,
          "code": "BRAND_NOT_FOUND",
          "message": "Brand not found"
        }
      }
    }
  },
  "get": {
    "endpoint": "GET /api/brands/{id}",
    "description": "Lấy chi tiết brand theo id.",
    "request": {
      "path": {
        "id": "number"
      }
    },
    "responses": {
      "200_ok": {
        "status": 200,
        "body": {
          "data": {
            "id": 15,
            "name": "Test Brand",
            "slug": "test-brand-1775710498",
            "logo": "https://example.com/logo.png",
            "description": "A test brand",
            "active": true,
            "createdAt": "2026-04-09T11:54:58.506284",
            "updatedAt": "2026-04-09T11:54:58.506284"
          }
        }
      },
      "404_not_found": {
        "status": 404,
        "body": {
          "status": 404,
          "code": "BRAND_NOT_FOUND",
          "message": "Brand not found"
        }
      }
    }
  },
  "hard-delete": {
    "endpoint": "DELETE /api/brands/{id}/permanent",
    "description": "Xóa vĩnh viễn brand. Chỉ cho phép với brand đã soft deleted. Block nếu có products.",
    "request": {
      "path": {
        "id": "number"
      }
    },
    "responses": {
      "200_ok": {
        "status": 200,
        "body": {
          "message": "Brand permanently deleted"
        }
      },
      "404_not_found": {
        "status": 404,
        "body": {
          "status": 404,
          "code": "BRAND_NOT_FOUND",
          "message": "Deleted brand not found. Soft delete first before permanent delete."
        }
      }
    },
    "notes": [
      "Phải soft delete trước",
      "Block nếu brand có products liên kết"
    ]
  },
