    "request": {
      "path": {
        "id": "number"
      }
    },
    "responses": {
      "200_ok": {
        "status": 200,
        "body": {
          "message": "Brand restored successfully"
        }
      },
      "404_not_found": {
        "status": 404,
        "body": {
          "status": 404,
          "code": "BRAND_NOT_FOUND",
          "message": "Deleted brand not found"
        }
      }
    }
  },
