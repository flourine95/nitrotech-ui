        }
      },
      "409_slug_exists": {
        "status": 409,
        "body": {
          "status": 409,
          "code": "CATEGORY_SLUG_EXISTS",
          "message": "Slug already exists"
        }
      },
      "404_parent_not_found": {
        "status": 404,
        "body": {
          "status": 404,
          "code": "CATEGORY_NOT_FOUND",
          "message": "Parent category not found"
        }
      }
    }
  },
  "delete": {
    "endpoint": "DELETE /api/categories/{id}",
    "description": "Soft delete category. Block nếu còn active children hoặc có products.",
    "request": {
      "path": {
        "id": "number"
      }
    },
    "responses": {
      "409_has_children": {
        "status": 409,
        "body": {
          "status": 409,
          "code": "CATEGORY_HAS_CHILDREN",
          "message": "Cannot delete category with active subcategories. Delete or move them first."
        }
      },
      "200_ok": {
        "status": 200,
        "body": {
          "message": "Category deleted successfully"
        }
      },
      "404_not_found": {
        "status": 404,
        "body": {
          "status": 404,
          "code": "CATEGORY_NOT_FOUND",
          "message": "Category not found"
        }
      }
    },
    "notes": [
      "Phải xóa hoặc move children trước khi xóa parent",
      "Block nếu category có products (productCount > 0)",
      "Dùng GET /{id} để check productCount trước khi delete"
    ]
  },
  "get": {
    "endpoint": "GET /api/categories/{id}",
    "description": "Lấy chi tiết category theo id. Response có breadcrumb path và productCount.",
    "request": {
      "path": {
        "id": "number"
      }
    },
    "responses": {
      "200_ok": {
        "status": 200,
        "body": {
          "data": {
