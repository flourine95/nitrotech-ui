  "move-down": {
    "endpoint": "PATCH /api/categories/{id}/move-down",
    "description": "Move category xuống 1 vị trí (swap với sibling sau đó).",
    "request": {
      "path": {
        "id": "number"
      }
    },
    "responses": {
      "200_ok": {
        "status": 409,
        "body": {
          "status": 409,
          "code": "ALREADY_LAST",
          "message": "Category is already at the last position"
        }
      },
      "409_already_last": {
        "status": 409,
        "body": {
          "status": 409,
          "code": "ALREADY_LAST",
          "message": "Category is already at the last position"
        }
      }
    },
    "notes": [
      "Chỉ swap trong cùng parent",
      "Throw ALREADY_LAST nếu đã ở cuối cùng"
    ]
  },
  "move-up": {
    "endpoint": "PATCH /api/categories/{id}/move-up",
    "description": "Move category lên 1 vị trí (swap với sibling trước đó).",
    "request": {
      "path": {
        "id": "number"
      }
    },
    "responses": {
      "200_ok": {
        "status": 409,
        "body": {
          "status": 409,
          "code": "ALREADY_FIRST",
          "message": "Category is already at the first position"
        }
      },
      "409_already_first": {
        "status": 409,
        "body": {
          "status": 409,
          "code": "ALREADY_FIRST",
          "message": "Category is already at the first position"
        }
      }
    },
    "notes": [
      "Chỉ swap trong cùng parent",
      "Throw ALREADY_FIRST nếu đã ở đầu tiên"
    ]
  },
