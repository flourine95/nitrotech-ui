      "path": {
        "id": "number"
      },
      "body": {
        "name": "string",
        "slug": "string",
        "description": "string",
        "image": "string",
        "parentId": "number",
        "active": "boolean"
      }
    },
    "responses": {
      "200_ok": {
        "status": 200,
