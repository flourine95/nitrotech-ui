      "body": {
        "token": "<uuid-from-email>"
      }
    },
    "responses": {
      "200_success": {
        "status": 200,
        "body": {
          "message": "Email verified successfully"
        }
      },
      "422_invalid_token": {
        "status": 422,
        "body": {
          "status": 422,
          "code": "INVALID_VERIFICATION_TOKEN",
          "message": "Verification token is invalid or has expired"
        }
      },
      "422_validation": {
        "status": 422,
        "body": {
          "status": 422,
          "code": "VALIDATION_ERROR",
          "message": "Validation failed",
