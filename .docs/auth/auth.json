        "body": {
          "status": 422,
          "code": "INVALID_RESET_TOKEN",
          "message": "Password reset token is invalid or expired"
        }
      },
      "422_validation": {
        "status": 422,
        "body": {
          "status": 422,
          "code": "VALIDATION_ERROR",
          "message": "Validation failed",
          "errors": {
            "newPassword": "Password must be at least 6 characters",
            "token": "Token is required"
          }
        }
      }
    }
  },
